CREATE TABLE IF NOT EXISTS UserProfile (
    id        INTEGER PRIMARY KEY AUTOINCREMENT,
    name      TEXT,
    createdAt INTEGER NOT NULL
);

getProfile:
SELECT * FROM UserProfile LIMIT 1;

insertProfile:
INSERT INTO UserProfile (name, createdAt) VALUES (:name, :createdAt);

updateName:
UPDATE UserProfile SET name = :name WHERE id = :id;

deleteProfile:
DELETE FROM UserProfile WHERE id = :id;
